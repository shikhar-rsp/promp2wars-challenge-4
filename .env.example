# =============================================================================
# ATLAS — Environment Configuration
# Copy to .env and fill in. NEVER commit real secrets. All AI keys are
# server-side only and are never exposed to the browser bundle.
# =============================================================================

# --- AI Providers (failover order: OpenRouter -> Groq -> Cerebras -> Gemini) --
# At least ONE key is required. The AI layer degrades gracefully to a
# deterministic local simulator if none are present (great for offline demos).
OPENROUTER_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=

# Optional model overrides (sensible defaults are baked in per provider)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_MODEL=llama-3.3-70b
GEMINI_MODEL=gemini-2.0-flash

# --- API server ---------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
# Comma-separated allowlist for CORS (the web origin)
CORS_ORIGINS=http://localhost:3000
# Secret used to sign the demo session cookies (min 32 chars in production)
SESSION_SECRET=change-me-in-production-min-32-characters-long

# --- Supabase (auth + persistence). Optional for the local demo. --------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only. Never ship this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Web app (only NEXT_PUBLIC_* values reach the browser) --------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
